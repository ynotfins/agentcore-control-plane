{
  "type": "object",
  "properties": {
    "library": {
      "type": "string",
      "description": "Library name."
    },
    "version": {
      "type": "string",
      "description": "Library version (exact or X-Range, optional)."
    },
    "query": {
      "type": "string",
      "description": "Documentation search query."
    },
    "limit": {
      "type": "number",
      "default": 5,
      "description": "Maximum number of results."
    }
  },
  "required": [
    "library",
    "query"
  ],
  "additionalProperties": false,
  "$schema": "http://json-schema.org/draft-07/schema#"
}
