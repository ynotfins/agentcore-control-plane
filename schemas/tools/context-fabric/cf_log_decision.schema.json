{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "description": "Short name for the decision."
    },
    "rationale": {
      "type": "string",
      "minLength": 1,
      "maxLength": 600,
      "description": "Why this decision was made."
    },
    "tags": {
      "description": "Optional tags.",
      "maxItems": 10,
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 30
      }
    }
  },
  "required": [
    "title",
    "rationale"
  ]
}
