  "host": "127.0.0.1",
  "port": 8080,
  "auth": {
    "type": "bearer",
    "header_name": "Authorization",
    "env_var_name": "BIFROST_MCP_VIRTUAL_KEY",
    "header_template": "Bearer ${env:BIFROST_MCP_VIRTUAL_KEY}"
  },
  "transport": "http/streamable",
  "timeout_seconds": 300,
  "client_render_hints": {
    "cursor": {
      "enabled": true,
      "config_path": "C:\\Users\\ynotf\\.cursor\\mcp.json",
      "syntax": "cursor_mcp_json",
      "supports_env_headers": true,
      "notes": [
        "Use type http/url + headers Authorization Bearer ${env:BIFROST_MCP_VIRTUAL_KEY}"
      ]
    },
    "codex": {
      "enabled": true,
      "config_path": "C:\\Users\\ynotf\\.codex\\config.toml",
      "syntax": "codex_toml",
      "supports_env_headers": true,
      "notes": [
        "Replace [mcp_servers.*] baseline entries with single agentcore-gateway http server"
      ]
    },
    "claude-code": {
      "enabled": true,
